# Copy this file to .env and fill in values before running the application.

# SQLite (default — zero setup):
DATABASE_URL="file:./dev.db"

# PostgreSQL (production):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/shift_management"

# JWT — use a long random string in production.
JWT_SECRET="change_this_to_a_long_random_secret"
JWT_EXPIRES_IN="7d"

# Express API server port (Next.js proxies /api/* here).
PORT=3001
NODE_ENV="development"
