generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  memberships RoomMember[]
  assignments ShiftAssignment[]
}

model Room {
  id        String   @id @default(uuid())
  number    Int      @unique
  name      String
  createdAt DateTime @default(now())

  members     RoomMember[]
  locations   ShiftLocation[]
  timeBlocks  TimeBlock[]
  assignments ShiftAssignment[]
}

/// role is one of: 'ADMIN' | 'PARTICIPANT'
model RoomMember {
  roomId String
  userId String
  role   String

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([roomId, userId])
}

model ShiftLocation {
  id     String @id @default(uuid())
  roomId String
  name   String

  room        Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignments ShiftAssignment[]
}

/// Reusable named time block (e.g. "Morning", startTime "08:00", endTime "16:00")
model TimeBlock {
  id        String @id @default(uuid())
  roomId    String
  name      String
  startTime String
  endTime   String

  room        Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  assignments ShiftAssignment[]
}

model ShiftAssignment {
  id              String @id @default(uuid())
  roomId          String
  timeBlockId     String
  shiftLocationId String
  userId          String
  date            String  // "YYYY-MM-DD"

  room          Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  timeBlock     TimeBlock     @relation(fields: [timeBlockId], references: [id], onDelete: Cascade)
  shiftLocation ShiftLocation @relation(fields: [shiftLocationId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([timeBlockId, shiftLocationId, userId, date])
}
